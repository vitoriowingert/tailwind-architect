{
  "name": "tailwind-architect",
  "version": "1.0.8",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitoriowingert/tailwind-architect.git"
  },
  "type": "module",
  "bin": {
    "tailwind-architect": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "logo.png"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../logo.png ./logo.png 2>/dev/null || true",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tailwind-architect/core": "1.0.8"
  }
}
